# Copy to .env.local and fill in.

# --- Postgres (Neon) -------------------------------------------------------
# Neon → Create project → Connection string (pooled). Include ?sslmode=require.
DATABASE_URL=postgres://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Set to "0" to disable TLS verification (not recommended).
# DATABASE_SSL=1

# --- Admin auth ------------------------------------------------------------
# The password you'll type at /admin/login. Use something long and random.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# Secret used to sign the admin session cookie (>=32 bytes of entropy).
# Generate:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SESSION_SECRET=generate-a-32+-byte-random-base64-string

# --- Netlify Blobs (optional in local dev) --------------------------------
# Netlify sets BLOBS_CONTEXT automatically in prod/build/dev environments.
# For seeding from your laptop against production Blobs, set these two:
# NETLIFY_SITE_ID=
# NETLIFY_TOKEN=
