{
  "name": "jp-archive",
  "version": "1.0.0",
  "private": true,
  "description": "Joshua Powell · Prop Archive",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:auto": "next dev",
    "admin": "concurrently -k -s first -n next,open \"next dev -p 3000\" \"wait-on http://localhost:3000 && open-cli http://localhost:3000/admin\"",
    "build": "node scripts/prebuild-static.mjs --out && next build && node scripts/prebuild-static.mjs --in",
    "build:full": "next build",
    "start": "next start -p 3000",
    "seed": "node scripts/seed-artifacts.mjs",
    "lint": "next lint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "exifr": "^7.1.3",
    "next": "^16.2.4",
    "papaparse": "5.4.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/papaparse": "5.3.15",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "concurrently": "9.1.0",
    "open-cli": "8.0.0",
    "typescript": "5.7.2",
    "wait-on": "8.0.1"
  }
}
